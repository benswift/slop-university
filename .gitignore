# Claude Code working directory --- ignore everything except committed slash commands
.claude/*
!.claude/commands/

# typst compile cache
.typst-cache/

# logfiles from cron runs
logs/

# generated outputs are kept locally only, not committed
output/*-images/
output/*-charts/
output/*.png
output/*.jpg
output/*.typ
output/*.pdf
output/pdf/
output/overviews/

# impeccable tool cache (regenerated by a hook; not part of the project)
.impeccable/

# python bytecode
__pycache__/

# local-only ANU-themed preset snapshot (never public, never published)
private/

# local-only agent instructions (documents the private capability)
CLAUDE.local.md

# excluded from the public repo cut (files stay in the local tree and the
# private archive): ANU media-library photos (photographer-credited, not
# redistributable) and planning files that describe private capabilities
references/*.avif
backlog/
docs/
