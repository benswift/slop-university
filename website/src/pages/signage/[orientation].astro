---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { fullTitle } from "../../lib/outputs";
import { thumbnail } from "../../lib/thumbnails";
import backdrop from "../../assets/signage/backdrop.avif";

// Chromeless, fullscreen e-signage view of the most recent research poster in a
// given orientation. Built for a kiosk browser (the 8K landscape panel today at
// /signage/landscape; a future portrait screen at /signage/portrait): no site
// chrome, no theme layout --- just the poster, letterboxed on black. The actual
// PDF page is rendered to a canvas at device resolution via PDF.js, so the
// vector text stays crisp at any display size.
//
// A panel that is physically portrait but whose framebuffer is landscape (a
// landscape-native screen mounted on its side, with no OS-level rotation) can
// use /signage/portrait/?rotate=cw (or ?rotate=ccw): it serves the same portrait
// posters but rotates the stage 90 degrees in CSS so the poster stands upright
// once the panel's physical rotation is accounted for. The stage's layout box is
// swapped to the panel's true (portrait) dimensions before rotating, so the
// letterbox maths and the PDF render resolution stay correct. Flip cw/ccw to
// match the way the panel was turned --- read client-side, so no rebuild needed.
//
// Because the site is static, "latest" is resolved at build time; the /publish
// tick rebuilds on each new output, and the page reloads itself on an interval
// so a fresh deploy swaps the poster in unattended.
//
// Orientation isn't in the content schema, but the first-page thumbnail is
// rendered from the PDF page, so its dimensions carry the true orientation. A
// poster without a thumbnail is skipped (orientation unknowable) rather than
// risk showing it in the wrong-shaped frame.
export function getStaticPaths() {
  return [{ params: { orientation: "landscape" } }, { params: { orientation: "portrait" } }];
}

const { orientation } = Astro.params;
const isLandscape = orientation === "landscape";

const posters = (await getCollection("outputs"))
  .filter((entry) => entry.data.preset === "research-poster")
  .map((entry) => ({ entry, thumb: thumbnail(entry.id) }))
  .filter(({ thumb }) => thumb && (isLandscape ? thumb.width >= thumb.height : thumb.height > thumb.width))
  .sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime());

// If no poster matches this orientation yet, degrade to a quiet placeholder
// rather than throwing --- an empty orientation must never fail the whole
// unattended site build.
const latest = posters[0];
const pdfUrl = latest?.entry.data.pdf;
const thumb = latest?.thumb;
const title = latest ? fullTitle(latest.entry.data) : "Slop University";

// Refresh the whole page hourly to pick up new deploys.
const RELOAD_MS = 60 * 60 * 1000;

// An asset that wouldn't load (the poster PDF, or the backdrop) retries on this
// much shorter cycle instead. A cold boot on wifi can drop the two largest
// assets mid-flight --- the clock steps on first NTP sync, tailscaled reads the
// jump as a wake and rebinds the link, and anything still streaming dies.
// Waiting a full hour to recover from a blip is the wrong trade for an
// unattended sign.
//
// An orientation with no poster at all isn't degraded in this sense: only a
// rebuild can fill it, so it waits for the hourly reload like everything else.
const RETRY_MS = 60 * 1000;

// The poster's aspect ratio, known at build time from the thumbnail. Drives the
// CSS box so the poster scales up to fill a large panel, not just down to fit a
// small one --- `max-width`/`max-height` alone would cap it and never enlarge.
const posterAspect = thumb ? thumb.width / thumb.height : 1;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} --- Slop University signage</title>
    <style>
      :root {
        color-scheme: dark;
      }

      html,
      body {
        margin: 0;
        height: 100%;
        background: #000;
        overflow: hidden;
      }

      /* House-style two-ink field behind the letterboxed poster, filling the
         panel's aspect gap instead of black bars. `cover` keeps it full-bleed
         at any panel ratio; #000 stays as the base while the image loads. */
      #backdrop {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
      }

      /* Kiosk: no cursor, no text selection, no touch callouts. */
      body {
        cursor: none;
        user-select: none;
        -webkit-user-select: none;
      }

      #stage {
        position: relative;
        z-index: 1;
        display: grid;
        place-items: center;
        width: 100vw;
        height: 100vh;
      }

      /* Both the canvas and the fallback image occupy the same cell and fit
         the viewport preserving the poster's aspect ratio. A soft shadow lifts
         the light poster off the dark house field.

         Size the box from the aspect ratio rather than `max-width`/`max-height`:
         those cap a large intrinsic size down to the viewport but never scale a
         small one up, so a 5200px canvas buffer would sit letterboxed at 68%
         width on a 7680px 8K panel. Taking the smaller of the width- and
         height-bound fit reproduces `object-fit: contain`, but as the element's
         real box, so the shadow still hugs the poster's edge. */
      #poster,
      #fallback {
        aspect-ratio: var(--poster-aspect);
        width: min(100vw, calc(100vh * var(--poster-aspect)));
        height: auto;
        object-fit: contain;
        box-shadow: 0 0 4vmin rgba(0, 0, 0, 0.55);
      }

      #poster[hidden],
      #fallback[hidden] {
        display: none;
      }

      /* Physically-portrait panel with a landscape framebuffer (see the head
         comment). `?rotate=cw|ccw` swaps the stage's layout box to the panel's
         true portrait dimensions (width <- 100vh, height <- 100vw) then spins it
         90deg. Because clientWidth/clientHeight report the pre-transform box, the
         canvas still renders at the panel's real resolution; the transform is
         purely how it lands on the glass. */
      body.rotate #stage {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100vh;
        height: 100vw;
        transform: translate(-50%, -50%) rotate(var(--rotate, 90deg));
      }

      /* Same contain-fit as the un-rotated poster, but measured against the
         rotated stage (vw/vh swapped) rather than the raw viewport. */
      body.rotate #poster,
      body.rotate #fallback {
        width: min(100vh, calc(100vw * var(--poster-aspect)));
      }
    </style>
  </head>
  <body>
    <Image id="backdrop" src={backdrop} alt="" loading="eager" aria-hidden="true" />
    <main
      id="stage"
      aria-label={`Research poster: ${title}`}
      data-pdf={pdfUrl}
      data-reload-ms={RELOAD_MS}
      data-retry-ms={RETRY_MS}
      style={`--poster-aspect: ${posterAspect}`}
    >
      <canvas id="poster" hidden></canvas>
      {
        thumb && (
          <img id="fallback" src={thumb.src} alt={`Poster: ${title}`} width={thumb.width} height={thumb.height} />
        )
      }
    </main>

    <script>
      // A bundled module script (no `define:vars`, which would force a
      // non-module inline script and leave these bare imports unresolved at
      // runtime). Build-time config rides in on `#stage` data attributes.
      //
      // Use pdf.js's *legacy* build: it transpiles + polyfills for older
      // engines (both main thread and worker). The Raspberry Pi signage kiosk
      // runs Chromium 136, which lacks Map.prototype.getOrInsertComputed (V8
      // ~13.9 / Chrome ~137); the default build calls it during render and
      // throws, silently falling back to the thumbnail. The legacy build ships
      // its own polyfill, so the poster actually renders there.
      import * as pdfjs from "pdfjs-dist/legacy/build/pdf.mjs";
      import workerUrl from "pdfjs-dist/legacy/build/pdf.worker.min.mjs?url";

      pdfjs.GlobalWorkerOptions.workerSrc = workerUrl;

      const stage = document.getElementById("stage");
      const pdfUrl = stage?.dataset.pdf;
      const reloadMs = Number(stage?.dataset.reloadMs) || 0;
      const retryMs = Number(stage?.dataset.retryMs) || 0;

      // A physically-portrait panel with a landscape framebuffer asks for
      // rotation via `?rotate=cw|ccw`. Toggle the CSS mode up front, before the
      // first render, so fitScale measures the rotated (portrait) stage box.
      const rotate = new URLSearchParams(location.search).get("rotate");
      if (rotate === "cw" || rotate === "ccw") {
        document.body.classList.add("rotate");
        document.body.style.setProperty("--rotate", rotate === "ccw" ? "-90deg" : "90deg");
      }

      const canvas = document.getElementById("poster") as HTMLCanvasElement | null;
      const fallback = document.getElementById("fallback");
      const backdrop = document.getElementById("backdrop") as HTMLImageElement | null;

      // Chromium's max canvas dimension. Exceeding it yields a blank canvas.
      const MAX_CANVAS_PX = 8192;

      const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

      // Exponential backoff, capped: a boot-time blip clears in seconds, but a
      // genuinely unreachable origin shouldn't be hammered until the next
      // whole-page retry comes round.
      const backoff = (attempt: number) => Math.min(30_000, 500 * 2 ** attempt);

      const settled = (img: HTMLImageElement) =>
        img.complete
          ? Promise.resolve()
          : new Promise<void>((r) => {
              img.addEventListener("load", () => r(), { once: true });
              img.addEventListener("error", () => r(), { once: true });
            });

      // `complete` with a zero `naturalWidth` is how a failed decode or a
      // severed transfer presents. Re-request under a fresh query so we bypass
      // any cached error entry.
      const loaded = (img: HTMLImageElement) => img.complete && img.naturalWidth > 0;

      async function keepBackdrop(img: HTMLImageElement, attempts = 6) {
        const base = img.src;
        await settled(img);
        for (let n = 0; n < attempts && !loaded(img); n++) {
          await sleep(backoff(n));
          img.src = `${base}${base.includes("?") ? "&" : "?"}retry=${n + 1}`;
          await settled(img);
        }
        if (!loaded(img)) console.error("signage: backdrop failed to load", base);
        return loaded(img);
      }

      async function withRetry<T>(fn: () => Promise<T>, attempts = 4): Promise<T> {
        let last: unknown;
        for (let n = 0; n < attempts; n++) {
          try {
            return await fn();
          } catch (err) {
            last = err;
            await sleep(backoff(n));
          }
        }
        throw last;
      }

      // Render at exactly the device pixels the poster will occupy: the CSS box
      // is the viewport-fitted rectangle, so multiplying by the device pixel
      // ratio gives a 1:1 buffer. Crisp on a 1080p test monitor and on a native
      // 8K panel alike, without a fixed target resolution that is simultaneously
      // wasteful on the former and too small on the latter.
      function fitScale(base: { width: number; height: number }) {
        const dpr = window.devicePixelRatio || 1;
        const box = Math.min(
          (stage!.clientWidth || window.innerWidth) / base.width,
          (stage!.clientHeight || window.innerHeight) / base.height,
        );
        return Math.min(box * dpr, MAX_CANVAS_PX / base.width, MAX_CANVAS_PX / base.height);
      }

      let renderTask: { cancel: () => void; promise: Promise<void> } | null = null;

      async function draw(el: HTMLCanvasElement, page: any) {
        renderTask?.cancel();
        const base = page.getViewport({ scale: 1 });
        const vp = page.getViewport({ scale: fitScale(base) });
        el.width = Math.round(vp.width);
        el.height = Math.round(vp.height);
        renderTask = page.render({ canvas: el, viewport: vp });
        await renderTask!.promise;
        renderTask = null;

        // Pin the box to the page's true ratio (the thumbnail's, used for the
        // fallback, can differ by a rounding step).
        stage!.style.setProperty("--poster-aspect", String(vp.width / vp.height));
        el.hidden = false;
        if (fallback) fallback.hidden = true;
      }

      async function renderPoster() {
        // Bind to non-null locals so the closures keep the narrowing (the
        // placeholder page has no canvas and no pdf: nothing to do).
        if (!pdfUrl || !canvas || !stage) return true;
        const el = canvas;

        const page = await withRetry(async () => {
          const pdf = await pdfjs.getDocument({ url: pdfUrl }).promise;
          const first = await pdf.getPage(1);
          await draw(el, first);
          return first;
        });

        // The panel can change mode under us --- a fresh EDID on hotplug, or a
        // compositor scale change. Re-render at the new device resolution rather
        // than letting the browser rescale a stale buffer.
        let debounce: ReturnType<typeof setTimeout>;
        window.addEventListener("resize", () => {
          clearTimeout(debounce);
          debounce = setTimeout(() => void draw(el, page).catch(() => {}), 250);
        });
        return true;
      }

      // Reload on an interval so a new deploy's poster appears without anyone
      // touching the display. Armed unconditionally and up front: a hung fetch
      // must never leave the sign with no path back.
      if (reloadMs) setTimeout(() => location.reload(), reloadMs);

      const posterOk = renderPoster().catch((err) => {
        // Leave the fallback thumbnail on screen; log for the kiosk console.
        console.error("signage: PDF render failed, showing thumbnail fallback", err);
        return false;
      });
      const backdropOk = backdrop ? keepBackdrop(backdrop) : Promise.resolve(true);

      // A degraded render comes back around sooner than the hourly tick.
      void Promise.all([posterOk, backdropOk]).then(([poster, back]) => {
        if (!(poster && back) && retryMs) setTimeout(() => location.reload(), retryMs);
      });
    </script>
  </body>
</html>
