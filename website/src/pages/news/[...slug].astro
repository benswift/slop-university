---
import { getCollection, getEntry, render } from "astro:content";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import OpenGraph from "../../components/OpenGraph.astro";
import { siteConfig } from "../../site-config";
import { getPeople, personIdByName } from "../../lib/canon";
import { formatAud, getSchemes, schemeById } from "../../lib/grants";
import { newsPostHero } from "../../lib/heroes";
import { fullTitle } from "../../lib/outputs";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const output = entry.data.output ? await getEntry("outputs", entry.data.output) : undefined;
// A press release shares the hero of the output it announces; a grant award or
// an institutional notice carries its own.
const hero = newsPostHero(entry.id, output?.id);

// A grant announcement closes with the award's details --- the news post is
// the award's public record (grants have no landing page of their own).
const grant = entry.data.grant ? await getEntry("grants", entry.data.grant) : undefined;
const scheme = grant ? schemeById(await getSchemes(), grant.data.scheme) : undefined;
const people = grant ? await getPeople() : [];
const grantees = (grant?.data.grantees ?? []).map((name) => ({
  name,
  id: personIdByName(people, name),
}));

const dateFormat = new Intl.DateTimeFormat("en-AU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  heroImage={hero}
  heroImageAlt={hero ? entry.data.title : undefined}
  {...siteConfig}
>
  <OpenGraph
    slot="head"
    title={entry.data.title}
    description={entry.data.description}
    type="article"
    image={hero}
    imageAlt={hero ? entry.data.title : undefined}
  />
  {entry.data.subtitle && <p class="deck">{entry.data.subtitle}</p>}
  <p class="dateline">
    <time datetime={entry.data.date.toISOString()}>{dateFormat.format(entry.data.date)}</time>
  </p>
  <Content />
  {
    output && (
      <p class="output-link">
        <a href={`/outputs/${output.id}/`}>
          Read the output: <cite>{fullTitle(output.data)}</cite>
        </a>{" "}
        (doi:{output.data.doi})
      </p>
    )
  }
  {
    grant && (
      <p class="output-link">
        {scheme?.data.name ?? grant.data.scheme}: <cite>{grant.data.name}</cite> ·{" "}
        {formatAud(grant.data.value)} · awarded to{" "}
        {grantees.map((grantee, i) => (
          <>
            {i > 0 && ", "}
            {grantee.id ? <a href={`/people/${grantee.id}/`}>{grantee.name}</a> : grantee.name}
          </>
        ))}
      </p>
    )
  }
</ContentLayout>

<style>
  /* The headline's deck, sitting under the punchy hero head --- larger than
     body copy, lighter than the h1. Mirrors the output landing page. */
  .deck {
    margin-block: calc(-1 * var(--at-spacing-sm)) var(--at-spacing-md);
    font-size: var(--at-font-size-h4);
    font-weight: 400;
    line-height: 1.3;
    color: var(--at-text-muted, inherit);
    text-wrap: balance;
  }

  .dateline {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  .output-link {
    padding: var(--at-spacing-md);
    border: 1px solid var(--at-divider);
    background: var(--at-bg-alt);
  }
</style>
