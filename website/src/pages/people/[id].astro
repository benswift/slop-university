---
import { Image } from "astro:assets";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import OpenGraph from "../../components/OpenGraph.astro";
import { siteConfig } from "../../site-config";
import { getPeople, getSchools, outputsByAuthor, schoolIdByName } from "../../lib/canon";
import { formatAud, getSchemes, grantsByGrantee, schemeById } from "../../lib/grants";
import { headshot } from "../../lib/headshots";
import { personHero } from "../../lib/heroes";

export async function getStaticPaths() {
  const people = await getPeople();
  return people.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const person = entry.data;
const hero = personHero(entry.id);
const portrait = headshot(entry.id);
// The landscape hero already shows the researcher; fall back to the square
// headshot in the body only until that hero has been generated.
const showPortrait = !hero && portrait;

const schools = await getSchools();
const schoolId = schoolIdByName(schools, person.school);
const outputs = await outputsByAuthor(person.name);
const grants = await grantsByGrantee(person.name);
const schemes = grants.length > 0 ? await getSchemes() : [];

// Research indicators, computed straight from the outputs and grants
// collections --- deterministic dashboard-ware, nothing invented.
// Collaboration breadth is the distinct co-authors credited alongside this
// researcher; research income is the sum of their held grants and prizes.
const coAuthors = new Set(
  outputs.flatMap((o) => o.data.authors).filter((name) => name !== person.name),
);
const activeSince = Math.min(...outputs.map((o) => o.data.date.getFullYear()));
const income = grants.reduce((sum, g) => sum + g.data.value, 0);

const dateFormat = new Intl.DateTimeFormat("en-AU", { month: "long", year: "numeric" });
---

<ContentLayout
  title={person.name}
  description={person.title}
  heroImage={hero}
  heroImageAlt={hero ? `Portrait of ${person.name}` : undefined}
  {...siteConfig}
>
  <OpenGraph
    slot="head"
    title={person.name}
    description={person.title}
    type="profile"
    image={hero ?? portrait}
    imageAlt={hero || portrait ? `Portrait of ${person.name}` : undefined}
  />
  <div class:list={["profile", { framed: showPortrait }]}>
    {
      showPortrait && (
        <Image
          class="portrait"
          src={portrait}
          alt={`Portrait of ${person.name}`}
          width={480}
          height={480}
        />
      )
    }
    <div class="profile-body">
      <p class="title">{person.title}</p>
      <p class="school">
        {
          schoolId ? (
            <a href={`/schools/${schoolId}/`}>{person.school}</a>
          ) : (
            person.school
          )
        }
      </p>
      {person.web && (
        <p class="web"><a href={person.web}>{person.web}</a></p>
      )}
      <p>{person.bio}</p>
    </div>
  </div>

  {
    (outputs.length > 0 || income > 0) && (
      <section class="indicators" aria-labelledby="indicators-heading">
        <h2 id="indicators-heading">Research indicators</h2>
        <table class="metadata">
          <tbody>
            {outputs.length > 0 && (
              <>
                <tr>
                  <th scope="row">Research outputs</th>
                  <td>{outputs.length}</td>
                </tr>
                <tr>
                  <th scope="row">Collaboration breadth</th>
                  <td>
                    {coAuthors.size} co-author{coAuthors.size === 1 ? "" : "s"}
                  </td>
                </tr>
                <tr>
                  <th scope="row">Active since</th>
                  <td>{activeSince}</td>
                </tr>
              </>
            )}
            {income > 0 && (
              <tr>
                <th scope="row">Research income</th>
                <td>{formatAud(income)}</td>
              </tr>
            )}
          </tbody>
        </table>
      </section>
    )
  }

  {
    outputs.length > 0 && (
      <section class="outputs" aria-labelledby="outputs-heading">
        <h2 id="outputs-heading">Research outputs</h2>
        <ul role="list">
          {outputs.map((o) => (
            <li>
              <a href={`/outputs/${o.id}/`}>{o.data.title}</a>
              <span class="meta"> · {dateFormat.format(o.data.date)}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    grants.length > 0 && (
      <section class="grants" aria-labelledby="grants-heading">
        <h2 id="grants-heading">Grants and awards</h2>
        <ul role="list">
          {grants.map((g) => (
            <li>
              {g.data.name}
              <span class="meta">
                {" "}
                · {schemeById(schemes, g.data.scheme)?.data.name} · {formatAud(g.data.value)} ·{" "}
                {dateFormat.format(g.data.date)}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</ContentLayout>

<style>
  .profile.framed {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--at-spacing-xl);
    align-items: start;
  }

  .portrait {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--at-divider);
    box-shadow: var(--at-shadow-md);
  }

  .profile-body .title {
    font-size: var(--at-font-size-h4);
    font-weight: 600;
    margin-block: 0 var(--at-spacing-xs);
  }

  .profile-body .school {
    color: var(--at-text-muted);
    margin-block: 0 var(--at-spacing-md);
  }

  .indicators {
    margin-block-start: var(--at-spacing-2xl);
  }

  .metadata th {
    text-align: start;
    padding-inline-end: var(--at-spacing-lg);
    white-space: nowrap;
    vertical-align: top;
  }

  .outputs,
  .grants {
    margin-block-start: var(--at-spacing-2xl);
  }

  .outputs .meta,
  .grants .meta {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  @media (width <= 40rem) {
    .profile.framed {
      grid-template-columns: 1fr;
    }

    .portrait {
      max-width: 12rem;
    }
  }
</style>
