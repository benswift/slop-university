---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { Image } from "astro:assets";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import Pagination from "astro-theme-university/components/Pagination.astro";
import { siteConfig } from "../../site-config";
import { getPeople } from "../../lib/canon";
import { headshot } from "../../lib/headshots";
import { pageHero } from "../../lib/heroes";

// Rest-param pagination: page 1 renders at /people/, later pages at
// /people/2/, ... Roster ids are never bare numbers, so this can't collide
// with the /people/[id]/ profile pages.
export const getStaticPaths = (async ({ paginate }) => {
  const people = await getPeople();
  return paginate(people, { pageSize: 24 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;
---

<ContentLayout
  title="People"
  description="The researchers of Slop University."
  heroImage={pageHero("people")}
  heroImageAlt={pageHero("people") ? "The researchers of Slop University" : undefined}
  {...siteConfig}
>
  <p class="lead">
    The University's researchers, across its schools and research groups.
  </p>

  <ul class="people-grid" role="list">
    {
      page.data.map((person) => {
        const portrait = headshot(person.id);
        return (
          <li class="person-card">
            <a href={`/people/${person.id}/`}>
              {portrait && (
                <Image
                  src={portrait}
                  alt={`Portrait of ${person.data.name}`}
                  width={320}
                  height={320}
                  loading="lazy"
                />
              )}
              <span class="name">{person.data.name}</span>
            </a>
            <span class="title">{person.data.title}</span>
            <span class="school">{person.data.school}</span>
          </li>
        );
      })
    }
  </ul>

  {page.lastPage > 1 && <Pagination page={page} />}
</ContentLayout>

<style>
  .people-grid {
    list-style: none;
    padding: 0;
    margin-block-start: var(--at-spacing-xl);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--at-spacing-xl);
  }

  .person-card {
    display: flex;
    flex-direction: column;
    gap: var(--at-spacing-xs);
  }

  .person-card a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .person-card img {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--at-divider);
    box-shadow: var(--at-shadow-sm);
    margin-block-end: var(--at-spacing-sm);
  }

  .person-card .name {
    font-weight: 600;
    font-size: var(--at-font-size-h4);
  }

  .person-card a:hover .name {
    color: var(--at-primary);
  }

  .person-card .title {
    font-size: var(--at-font-size-sm);
  }

  .person-card .school {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }
</style>
