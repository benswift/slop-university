---
import { getCollection } from "astro:content";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import type { TopLevelSpec } from "vega-lite";
import {
  academicFte,
  chartSvg,
  countBy,
  cumulativeByYear,
  perFteByYear,
  vlConfig,
} from "../lib/performance";
import { siteConfig } from "../site-config";

const outputs = await getCollection("outputs");
const dates = outputs.map((o) => o.data.date);
const fte = academicFte();

const bySchool = countBy(outputs, (o) => o.data.school ?? "Slop University");

const width = 640;
const charts: { title: string; label: string; spec: TopLevelSpec }[] = [
  {
    title: "Outputs over time",
    label: "Cumulative research outputs by year",
    spec: {
      data: { values: cumulativeByYear(dates) },
      mark: { type: "line", point: true },
      encoding: {
        x: { field: "year", type: "ordinal", title: "Year" },
        y: {
          field: "outputs",
          type: "quantitative",
          title: "Cumulative outputs",
          axis: { tickMinStep: 1 },
        },
      },
      width,
      height: 220,
    },
  },
  {
    title: "Outputs by school",
    label: "Research outputs by school",
    spec: {
      data: { values: bySchool },
      mark: "bar",
      encoding: {
        y: { field: "key", type: "nominal", title: null, sort: "-x" },
        x: { field: "count", type: "quantitative", title: "Outputs", axis: { tickMinStep: 1 } },
      },
      width,
      height: 160,
    },
  },
  {
    title: "Output intensity",
    label: "Research outputs per academic FTE",
    spec: {
      data: { values: perFteByYear(dates, fte) },
      mark: "bar",
      encoding: {
        x: { field: "year", type: "ordinal", title: "Year" },
        y: { field: "perFte", type: "quantitative", title: "Outputs per academic FTE" },
      },
      width,
      height: 220,
    },
  },
];

// Each chart renders twice --- the site theme is a client-side toggle, so
// both variants ship and CSS displays the matching one (no chart JS).
const rendered = await Promise.all(
  charts.map(async (chart) => ({
    ...chart,
    light: await chartSvg({ ...chart.spec, config: vlConfig("light") }),
    dark: await chartSvg({ ...chart.spec, config: vlConfig("dark") }),
  })),
);

const stats = [
  { label: "Research outputs", value: outputs.length },
  { label: "DOIs minted", value: new Set(outputs.map((o) => o.data.doi)).size },
  { label: "Academic FTE", value: fte },
  {
    label: "Outputs per academic FTE",
    value: fte > 0 ? (outputs.length / fte).toFixed(2) : "—",
  },
];
---

<ContentLayout
  title="Research performance"
  description="The University's research output, measured."
  {...siteConfig}
>
  <p class="lead">
    The University measures what matters. These indicators are generated
    directly from the research repository and are updated with every deposit.
  </p>

  <dl class="stat-row">
    {
      stats.map((stat) => (
        <div class="stat">
          <dd>{stat.value}</dd>
          <dt>{stat.label}</dt>
        </div>
      ))
    }
  </dl>

  {
    rendered.map((chart) => (
      <>
        <h2>{chart.title}</h2>
        <div class="chart chart-light" role="img" aria-label={chart.label} set:html={chart.light} />
        <div class="chart chart-dark" role="img" aria-label={chart.label} set:html={chart.dark} />
      </>
    ))
  }
</ContentLayout>

<style>
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--at-spacing-lg);
    margin-block: var(--at-spacing-xl);
  }

  .stat {
    border-block-start: 2px solid var(--at-primary);
    padding-block-start: var(--at-spacing-sm);
  }

  .stat dd {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .stat dt {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  .chart {
    width: 100%;
    margin-block: var(--at-spacing-md) var(--at-spacing-xl);
  }

  .chart :global(svg) {
    width: 100%;
    height: auto;
  }

  /* The theme toggle stamps data-theme on <html>; prefers-color-scheme covers
     the no-JS case where no attribute is ever set. */
  .chart-dark {
    display: none;
  }

  :root[data-theme="dark"] .chart-light {
    display: none;
  }

  :root[data-theme="dark"] .chart-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .chart-light {
      display: none;
    }

    :root:not([data-theme]) .chart-dark {
      display: block;
    }
  }
</style>
