---
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import { siteConfig } from "../site-config";
import { academicFte, countBy, readLedger, vlConfig } from "../lib/performance";

const runs = readLedger();
const fte = academicFte();

const byYear = countBy(runs, (r) => String(new Date(r.date).getFullYear())).sort((a, b) =>
  a.key.localeCompare(b.key),
);
// Cumulative outputs climb monotonically, as the sector expects.
let cumulative = 0;
const cumulativeByYear = byYear.map(({ key, count }) => {
  cumulative += count;
  return { year: key, outputs: cumulative };
});
const bySchool = countBy(runs, (r) => r.school);
const perFte = byYear.map(({ key, count }) => ({
  year: key,
  perFte: Number((count / fte).toFixed(2)),
}));

const config = vlConfig();
const specs = {
  "rp-by-year": {
    $schema: "https://vega.github.io/schema/vega-lite/v6.json",
    description: "Cumulative research outputs by year",
    data: { values: cumulativeByYear },
    mark: { type: "line", point: true },
    encoding: {
      x: { field: "year", type: "ordinal", title: "Year" },
      y: {
        field: "outputs",
        type: "quantitative",
        title: "Cumulative outputs",
        axis: { tickMinStep: 1 },
      },
    },
    width: "container",
    height: 220,
    config,
  },
  "rp-by-school": {
    $schema: "https://vega.github.io/schema/vega-lite/v6.json",
    description: "Research outputs by school",
    data: { values: bySchool },
    mark: "bar",
    encoding: {
      y: { field: "key", type: "nominal", title: null, sort: "-x" },
      x: { field: "count", type: "quantitative", title: "Outputs", axis: { tickMinStep: 1 } },
    },
    width: "container",
    height: 160,
    config,
  },
  "rp-per-fte": {
    $schema: "https://vega.github.io/schema/vega-lite/v6.json",
    description: "Research outputs per academic FTE",
    data: { values: perFte },
    mark: "bar",
    encoding: {
      x: { field: "year", type: "ordinal", title: "Year" },
      y: { field: "perFte", type: "quantitative", title: "Outputs per academic FTE" },
    },
    width: "container",
    height: 220,
    config,
  },
};

const stats = [
  { label: "Research outputs", value: runs.length },
  { label: "DOIs minted", value: new Set(runs.map((r) => r.doi)).size },
  { label: "Academic FTE", value: fte },
  {
    label: "Outputs per academic FTE",
    value: fte > 0 ? (runs.length / fte).toFixed(2) : "—",
  },
];
---

<ContentLayout
  title="Research performance"
  description="The University's research output, measured."
  {...siteConfig}
>
  <p class="lead">
    The University measures what matters. These indicators are generated
    directly from the research repository's publication ledger and are updated
    with every deposit.
  </p>

  <dl class="stat-row">
    {
      stats.map((stat) => (
        <div class="stat">
          <dd>{stat.value}</dd>
          <dt>{stat.label}</dt>
        </div>
      ))
    }
  </dl>

  <h2>Outputs over time</h2>
  <div class="chart" id="rp-by-year" role="img" aria-label="Cumulative research outputs by year"></div>

  <h2>Outputs by school</h2>
  <div class="chart" id="rp-by-school" role="img" aria-label="Research outputs by school"></div>

  <h2>Output intensity</h2>
  <div class="chart" id="rp-per-fte" role="img" aria-label="Research outputs per academic FTE"></div>

  <script type="application/json" id="rp-specs" set:html={JSON.stringify(specs)} />
</ContentLayout>

<script>
  import vegaEmbed from "vega-embed";

  const specsEl = document.getElementById("rp-specs");
  if (specsEl?.textContent) {
    const specs = JSON.parse(specsEl.textContent) as Record<string, object>;
    for (const [id, spec] of Object.entries(specs)) {
      if (document.getElementById(id)) {
        vegaEmbed(`#${id}`, spec, { actions: false, renderer: "svg" });
      }
    }
  }
</script>

<style>
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--at-spacing-lg);
    margin-block: var(--at-spacing-xl);
  }

  .stat {
    border-block-start: 2px solid var(--at-primary);
    padding-block-start: var(--at-spacing-sm);
  }

  .stat dd {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .stat dt {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  .chart {
    width: 100%;
    margin-block: var(--at-spacing-md) var(--at-spacing-xl);
  }
</style>
