---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "astro-theme-university/layouts/BaseLayout.astro";
import Hero from "astro-theme-university/components/Hero.astro";
import Card from "astro-theme-university/components/Card.astro";
import CardGrid from "astro-theme-university/components/CardGrid.astro";
import Pagination from "astro-theme-university/components/Pagination.astro";
import heroImage from "../assets/images/hero.avif";
import BlueskyFeed from "../components/BlueskyFeed.astro";
import OpenGraph from "../components/OpenGraph.astro";
import OutputTypeBadge from "../components/OutputTypeBadge.astro";
import { siteConfig } from "../site-config";
import { newsPostHero } from "../lib/heroes";

// Rest-param pagination: page 1 renders at /, later pages at /2, /3, ...
export const getStaticPaths = (async ({ paginate }) => {
  const news = (await getCollection("news")).toSorted(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(news, { pageSize: 12 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;
const title =
  page.currentPage === 1 ? siteConfig.name : `${siteConfig.name} — news, page ${page.currentPage}`;

// A news post that announces an output carries that output's type badge, the
// same pill the outputs grid shows. Posts announcing a grant or an
// institutional notice reference no output and go unbadged.
const presetByOutputId = new Map(
  (await getCollection("outputs")).map((entry) => [entry.id, entry.data.preset]),
);

const dateFormat = new Intl.DateTimeFormat("en-AU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={title} {...siteConfig}>
  <OpenGraph
    slot="head"
    title={title}
    description="Research-led, metrics-forward, and continuously improving. News from the Office of Research Outputs."
    image={heroImage}
  />
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title={siteConfig.name}
    href="/rss.xml"
  />
  <Hero slot="hero" title="Slop University" image={heroImage} imageAlt="" />
  <p class="lead">
    Research-led, metrics-forward, and continuously improving. News from the
    Office of Research Outputs.
  </p>

  {
    page.total === 0 && (
      <p>
        Announcements of new research outputs appear here as they are
        published.
      </p>
    )
  }

  <CardGrid columns={2}>
    {
      page.data.map((entry) => {
        const preset = entry.data.output ? presetByOutputId.get(entry.data.output) : undefined;
        return (
          <div class="news-card">
            {preset && <OutputTypeBadge preset={preset} />}
            <Card
              title={entry.data.title}
              href={`/news/${entry.id}/`}
              image={newsPostHero(entry.id, entry.data.output)}
              imageAlt=""
              headingLevel="h2"
            >
              <p class="news-date">
                <time datetime={entry.data.date.toISOString()}>
                  {dateFormat.format(entry.data.date)}
                </time>
              </p>
              {entry.data.description && <p>{entry.data.description}</p>}
            </Card>
          </div>
        );
      })
    }
  </CardGrid>

  {page.lastPage > 1 && <Pagination page={page} />}

  {page.currentPage === 1 && <BlueskyFeed />}
</BaseLayout>

<style>
  /* The type badge (OutputTypeBadge) positions itself in the top-right corner
     and needs a positioned ancestor; the Card is an anchor in normal flow, so
     this wrapper provides it. Unbadged posts get a bare wrapper, which is inert. */
  .news-card {
    position: relative;
  }

  .news-date {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
    margin-block: 0 var(--at-spacing-xs);
  }
</style>
