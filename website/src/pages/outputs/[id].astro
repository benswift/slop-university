---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "astro-theme-university/layouts/BaseLayout.astro";
import Hero from "astro-theme-university/components/Hero.astro";
import OpenGraph from "../../components/OpenGraph.astro";
import { siteConfig } from "../../site-config";
import { bibtex, bibtexTokens, fullTitle, presetLabels } from "../../lib/outputs";
import { getPeople, getSchools, personIdByName, schoolIdByName } from "../../lib/canon";
import { outputHero } from "../../lib/heroes";
import { thumbnail } from "../../lib/thumbnails";

export async function getStaticPaths() {
  const outputs = await getCollection("outputs");
  return outputs.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const data = entry.data;
const hero = outputHero(entry.id);
const thumb = thumbnail(entry.id);
const citation = bibtex(entry.id, data);
const citationTokens = bibtexTokens(citation);
const doiUrl = `https://slop.university/doi/${data.doi}`;

// Resolve each credited author and the attributed school to their canon page.
// The content test guarantees these names all resolve, so the links never
// dangle; the plain-text fallback is belt-and-braces for a page rendered
// before the test runs.
const people = await getPeople();
const schools = await getSchools();
const authors = data.authors.map((name) => ({ name, id: personIdByName(people, name) }));
const schoolId = data.school ? schoolIdByName(schools, data.school) : undefined;

// Hero h1 carries only the punchy title; the subtitle rides underneath as a
// deck. The full title stays in the document <title> for the citable record.
const full = fullTitle(data);
const transitionName = `card-title-${Astro.url.pathname.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`;

const dateFormat = new Intl.DateTimeFormat("en-AU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={full} description={data.summary} {...siteConfig}>
  <OpenGraph
    slot="head"
    title={full}
    description={data.summary}
    type="article"
    image={hero ?? thumb}
    imageAlt={hero ? `Illustration for ${full}` : thumb ? `First page of ${full}` : undefined}
  />
  {
    hero ? (
      <Hero
        slot="hero"
        title={data.title}
        image={hero}
        imageAlt={`Illustration for ${full}`}
        transitionName={transitionName}
      />
    ) : (
      <h1 transition:name={transitionName}>{data.title}</h1>
    )
  }

  {data.subtitle && <p class="deck">{data.subtitle}</p>}
  <p class="lead">{data.summary}</p>

  <div class="record">
    <div class="record-main">
      <table class="metadata">
        <tbody>
          {
            authors.length > 0 && (
              <tr>
                <th scope="row">Authors</th>
                <td>
                  {authors.map((author, i) => (
                    <>
                      {i > 0 && ", "}
                      {author.id ? (
                        <a href={`/people/${author.id}/`}>{author.name}</a>
                      ) : (
                        author.name
                      )}
                    </>
                  ))}
                </td>
              </tr>
            )
          }
          {
            data.school && (
              <tr>
                <th scope="row">School</th>
                <td>
                  {schoolId ? <a href={`/schools/${schoolId}/`}>{data.school}</a> : data.school}
                </td>
              </tr>
            )
          }
          <tr>
            <th scope="row">Output type</th>
            <td>{presetLabels[data.preset]}</td>
          </tr>
          <tr>
            <th scope="row">Published</th>
            <td>
              <time datetime={data.date.toISOString()}>{dateFormat.format(data.date)}</time>
            </td>
          </tr>
          <tr>
            <th scope="row">DOI</th>
            <td><a href={doiUrl}>{data.doi}</a></td>
          </tr>
          {
            data.pages && (
              <tr>
                <th scope="row">Pages</th>
                <td>{data.pages}</td>
              </tr>
            )
          }
          <tr>
            <th scope="row">Version</th>
            <td>{data.version}</td>
          </tr>
          <tr>
            <th scope="row">Licence</th>
            <td>
              <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>
            </td>
          </tr>
        </tbody>
      </table>

      <p>
        <a class="download" href={data.pdf}>Download PDF</a>
      </p>

      <section class="cite-as" aria-labelledby="cite-as-heading">
        <h2 id="cite-as-heading">Cite as</h2>
        <pre><code>{citationTokens.map((t) => (t.kind === "plain" ? t.text : <span class={t.kind}>{t.text}</span>))}</code></pre>
        <button type="button" data-citation={citation}>Copy BibTeX</button>
      </section>
    </div>

    {
      thumb && (
        <a class="record-thumb" href={data.pdf}>
          <Image
            src={thumb}
            alt={`First page of ${full}`}
            widths={[224, 448]}
            sizes="(max-width: 48rem) 12rem, 14rem"
            loading="lazy"
          />
        </a>
      )
    }
  </div>
</BaseLayout>

<script>
  for (const button of document.querySelectorAll<HTMLButtonElement>("button[data-citation]")) {
    button.addEventListener("click", async () => {
      await navigator.clipboard.writeText(button.dataset.citation ?? "");
      const label = button.textContent;
      button.textContent = "Copied";
      setTimeout(() => {
        button.textContent = label;
      }, 1500);
    });
  }
</script>

<style>
  /* The title's subtitle, sitting under the punchy hero head. Reads as a
     deck: larger than body copy, lighter than the h1, distinct from the .lead
     summary that follows it. */
  .deck {
    margin-block: calc(-1 * var(--at-spacing-sm)) var(--at-spacing-md);
    font-size: var(--at-font-size-h4);
    font-weight: 400;
    line-height: 1.3;
    color: var(--at-text-muted, inherit);
    text-wrap: balance;
  }

  .record {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: var(--at-spacing-xl);
    align-items: start;
  }

  .record-thumb img {
    width: 100%;
    height: auto;
    border: 1px solid var(--at-divider);
    box-shadow: var(--at-shadow-md);
  }

  .metadata th {
    text-align: start;
    padding-inline-end: var(--at-spacing-lg);
    white-space: nowrap;
    vertical-align: top;
  }

  .download {
    font-weight: 600;
  }

  .cite-as {
    /* Two inks for the citation's syntax: the accent carries the structure
       (@misc, the field names), the bronze the cite key. Both are darkened in
       light mode and lifted in dark, the way the theme derives --at-link, so
       gold-on-cream still clears contrast. */
    --cite-accent: light-dark(oklch(from var(--at-primary) calc(l - 0.1) c h), var(--at-primary));
    --cite-key: light-dark(
      var(--at-secondary),
      oklch(from var(--at-secondary) calc(l + 0.28) c h)
    );

    border: 1px solid var(--at-divider);
    background: var(--at-bg-alt);
    padding: var(--at-spacing-md) var(--at-spacing-lg);
  }

  .cite-as .type {
    color: var(--cite-accent);
    font-weight: 600;
  }

  .cite-as .field {
    color: var(--cite-accent);
  }

  .cite-as .key {
    color: var(--cite-key);
  }

  .cite-as .value {
    color: var(--at-text);
  }

  .cite-as .punct {
    color: var(--at-text-muted);
  }

  .cite-as h2 {
    margin-block-start: 0;
    font-size: var(--at-font-size-h4);
  }

  .cite-as pre {
    overflow-x: auto;
    font-size: var(--at-font-size-sm);
  }

  .cite-as button {
    font: inherit;
    font-size: var(--at-font-size-sm);
    padding: var(--at-spacing-xs) var(--at-spacing-md);
    border: 1px solid var(--at-primary);
    border-radius: var(--at-border-radius);
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .cite-as button:hover {
    background: var(--at-accent-soft, rgb(185 125 28 / 10%));
  }

  @media (width <= 48rem) {
    .record {
      grid-template-columns: 1fr;
    }

    .record-thumb {
      order: -1;
      max-width: 12rem;
    }
  }
</style>
