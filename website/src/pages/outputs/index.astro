---
import { getCollection } from "astro:content";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import Card from "astro-theme-university/components/Card.astro";
import CardGrid from "astro-theme-university/components/CardGrid.astro";
import type { TopLevelSpec } from "vega-lite";
import { siteConfig } from "../../site-config";
import { presetLabels } from "../../lib/outputs";
import { academicFte, chartSvg, cumulativeByYear, vlConfig } from "../../lib/performance";
import { outputHero, pageHero } from "../../lib/heroes";
import { thumbnail } from "../../lib/thumbnails";

const outputs = (await getCollection("outputs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFormat = new Intl.DateTimeFormat("en-AU", {
  month: "long",
  year: "numeric",
});

const fte = academicFte();
const stats = [
  { label: "Research outputs", value: outputs.length },
  { label: "DOIs minted", value: new Set(outputs.map((o) => o.data.doi)).size },
  {
    label: "Outputs per academic FTE",
    value: fte > 0 ? (outputs.length / fte).toFixed(2) : "—",
  },
];

// One chart carries the trend line --- and the whole build-time Vega-Lite
// pipeline (static SVG, light/dark bake, slop palette) as a live reference for
// when the dashboard grows back. Renders twice; CSS shows the matching theme.
const spec: TopLevelSpec = {
  data: { values: cumulativeByYear(outputs.map((o) => o.data.date)) },
  mark: { type: "line", point: true },
  encoding: {
    x: { field: "year", type: "ordinal", title: "Year" },
    y: {
      field: "outputs",
      type: "quantitative",
      title: "Cumulative outputs",
      axis: { tickMinStep: 1 },
    },
  },
  width: 640,
  height: 220,
};
const chart = {
  label: "Cumulative research outputs by year",
  light: await chartSvg({ ...spec, config: vlConfig("light") }),
  dark: await chartSvg({ ...spec, config: vlConfig("dark") }),
};
---

<ContentLayout
  title="Research outputs"
  description="The published research outputs of Slop University."
  heroImage={pageHero("outputs")}
  heroImageAlt={pageHero("outputs") ? "The Slop University research repository" : undefined}
  {...siteConfig}
>
  <p class="lead">
    All research outputs of the University are published open access under CC
    BY 4.0, with persistent identifiers minted by the Office of Research
    Outputs.
  </p>

  <dl class="stat-row">
    {
      stats.map((stat) => (
        <div class="stat">
          <dd>{stat.value}</dd>
          <dt>{stat.label}</dt>
        </div>
      ))
    }
  </dl>

  <h2>Outputs over time</h2>
  <div class="chart chart-light" role="img" aria-label={chart.label} set:html={chart.light} />
  <div class="chart chart-dark" role="img" aria-label={chart.label} set:html={chart.dark} />

  <h2>Published outputs</h2>
  {
    outputs.length === 0 && (
      <p>The repository is awaiting its first deposit.</p>
    )
  }

  <CardGrid columns={2}>
    {
      outputs.map((entry) => (
        <Card
          title={entry.data.title}
          href={`/outputs/${entry.id}/`}
          image={outputHero(entry.id) ?? thumbnail(entry.id)}
          imageAlt=""
        >
          <p class="meta">
            {entry.data.authors.join(", ")}
            {entry.data.authors.length > 0 && " · "}
            {presetLabels[entry.data.preset]} ·{" "}
            {dateFormat.format(entry.data.date)} · doi:{entry.data.doi}
          </p>
          <p>{entry.data.summary}</p>
        </Card>
      ))
    }
  </CardGrid>
</ContentLayout>

<style>
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--at-spacing-lg);
    margin-block: var(--at-spacing-xl);
  }

  .stat {
    border-block-start: 2px solid var(--at-primary);
    padding-block-start: var(--at-spacing-sm);
  }

  .stat dd {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .stat dt {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  .chart {
    width: 100%;
    margin-block: var(--at-spacing-md) var(--at-spacing-xl);
  }

  .chart :global(svg) {
    width: 100%;
    height: auto;
  }

  /* The theme toggle stamps data-theme on <html>; prefers-color-scheme covers
     the no-JS case where no attribute is ever set. */
  .chart-dark {
    display: none;
  }

  :root[data-theme="dark"] .chart-light {
    display: none;
  }

  :root[data-theme="dark"] .chart-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .chart-light {
      display: none;
    }

    :root:not([data-theme]) .chart-dark {
      display: block;
    }
  }

  .meta {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
    margin-block: 0 var(--at-spacing-sm);
  }
</style>
