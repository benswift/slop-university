---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import Card from "astro-theme-university/components/Card.astro";
import CardGrid from "astro-theme-university/components/CardGrid.astro";
import Icon from "astro-theme-university/components/Icon.astro";
import Pagination from "astro-theme-university/components/Pagination.astro";
import { siteConfig } from "../../site-config";
import { formatAud, formatAudCompact } from "../../lib/grants";
import { presetBadgeLabels, presetIcons, presetLabels, presetSeries, seriesOrder } from "../../lib/outputs";
import { academicFte, chartSvg, performanceSpec, vlConfig } from "../../lib/performance";
import { outputHero, pageHero } from "../../lib/heroes";
import { thumbnail } from "../../lib/thumbnails";

// Rest-param pagination: page 1 renders at /outputs/, later pages at
// /outputs/2/, ... Output ids are never bare numbers, so this can't collide
// with the /outputs/[id]/ landing pages.
export const getStaticPaths = (async ({ paginate }) => {
  const outputs = (await getCollection("outputs")).toSorted(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(outputs, { pageSize: 12 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;
const firstPage = page.currentPage === 1;

const dateFormat = new Intl.DateTimeFormat("en-AU", {
  month: "long",
  year: "numeric",
});

// The dashboard (stat tiles + trend charts) summarises the whole collection,
// so it renders on page 1 only; later pages carry just the card grid.
const allOutputs = firstPage ? await getCollection("outputs") : [];
const allGrants = firstPage ? await getCollection("grants") : [];
const totalFunding = allGrants.reduce((sum, g) => sum + g.data.value, 0);

const fte = academicFte();
const stats = [
  { label: "Research outputs", value: allOutputs.length },
  {
    label: "Outputs per academic FTE",
    value: fte > 0 ? (allOutputs.length / fte).toFixed(2) : "—",
  },
  // The funding tiles arrive with the first award --- the repository predates
  // the university discovering research income.
  ...(totalFunding > 0
    ? [
        { label: "Funding awarded", value: formatAudCompact(totalFunding) },
        {
          label: "Research income per academic FTE",
          value: fte > 0 ? formatAud(totalFunding / fte) : "—",
        },
      ]
    : []),
];

// The trend chart carries the whole build-time Vega-Lite pipeline (static SVG,
// light/dark bake, slop palette). It renders twice; CSS shows the matching
// theme. Outputs and funding stack as two panels sharing one day axis --- see
// performanceSpec.
const spec = performanceSpec(
  allOutputs.map((o) => ({ date: o.data.date, series: presetSeries[o.data.preset] })),
  allGrants.map((g) => ({ date: g.data.date, value: g.data.value })),
  seriesOrder,
);
const chart =
  firstPage && allOutputs.length > 0
    ? {
        label:
          allGrants.length > 0
            ? "Cumulative research outputs by day split by output type, above cumulative research funding awarded on the same day axis"
            : "Cumulative research outputs by day, split by output type",
        light: await chartSvg({ ...spec, config: vlConfig("light") }),
        dark: await chartSvg({ ...spec, config: vlConfig("dark") }),
      }
    : undefined;
---

<ContentLayout
  title="Research outputs"
  description="The published research outputs of Slop University."
  heroImage={pageHero("outputs")}
  heroImageAlt={pageHero("outputs") ? "The Slop University research repository" : undefined}
  {...siteConfig}
>
  <p class="lead">
    All research outputs of the University are published open access under{" "}
    <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>, with
    persistent identifiers minted by the Office of Research Outputs.
  </p>

  {
    firstPage && (
      <dl class="stat-row">
        {stats.map((stat) => (
          <div class="stat">
            <dd>{stat.value}</dd>
            <dt>{stat.label}</dt>
          </div>
        ))}
      </dl>
    )
  }

  {
    chart && (
      <>
        <h2>Outputs and funding over time</h2>
        <div class="chart chart-light" role="img" aria-label={chart.label} set:html={chart.light} />
        <div class="chart chart-dark" role="img" aria-label={chart.label} set:html={chart.dark} />
      </>
    )
  }

  <h2>Published outputs</h2>
  {
    page.total === 0 && (
      <p>The repository is awaiting its first deposit.</p>
    )
  }

  <CardGrid columns={2}>
    {
      page.data.map((entry) => (
        <div class="output-card">
          <span class="type-badge" title={presetLabels[entry.data.preset]}>
            <Icon name={presetIcons[entry.data.preset]} size={16} />
            <span>{presetBadgeLabels[entry.data.preset]}</span>
          </span>
          <Card
            title={entry.data.title}
            href={`/outputs/${entry.id}/`}
            image={outputHero(entry.id) ?? thumbnail(entry.id)}
            imageAlt=""
          >
          <p class="meta">
            {entry.data.authors.join(", ")}
            {entry.data.authors.length > 0 && " · "}
            {dateFormat.format(entry.data.date)} · doi:{entry.data.doi}
          </p>
          <p>{entry.data.summary}</p>
          </Card>
        </div>
      ))
    }
  </CardGrid>

  {page.lastPage > 1 && <Pagination page={page} />}
</ContentLayout>

<style>
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--at-spacing-lg);
    margin-block: var(--at-spacing-xl);
  }

  .stat {
    border-block-start: 2px solid var(--at-primary);
    padding-block-start: var(--at-spacing-sm);
  }

  .stat dd {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .stat dt {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
  }

  .chart {
    width: 100%;
    margin-block: var(--at-spacing-md) var(--at-spacing-xl);
  }

  .chart :global(svg) {
    width: 100%;
    height: auto;
  }

  /* The theme toggle stamps data-theme on <html>; prefers-color-scheme covers
     the no-JS case where no attribute is ever set. */
  .chart-dark {
    display: none;
  }

  :root[data-theme="dark"] .chart-light {
    display: none;
  }

  :root[data-theme="dark"] .chart-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .chart-light {
      display: none;
    }

    :root:not([data-theme]) .chart-dark {
      display: block;
    }
  }

  .meta {
    color: var(--at-text-muted);
    font-size: var(--at-font-size-sm);
    margin-block: 0 var(--at-spacing-sm);
  }

  /* The badge sits in the card's top-right corner. The card itself is an
     anchor in normal flow, so a relatively-positioned wrapper gives the badge
     something to anchor to; pointer-events: none lets clicks fall through to
     the link underneath. */
  .output-card {
    position: relative;
  }

  .type-badge {
    position: absolute;
    inset-block-start: var(--at-spacing-sm);
    inset-inline-end: var(--at-spacing-sm);
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.3em 0.6em;
    border-radius: 999px;
    background: var(--at-primary);
    color: var(--at-white);
    font-size: var(--at-font-size-sm);
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.25);
  }

  /* The svg comes from the Icon component, so it carries no scope attribute of
     ours --- an unqualified `.type-badge svg` compiles to a selector that never
     matches. */
  .type-badge :global(svg) {
    flex-shrink: 0;
  }
</style>
