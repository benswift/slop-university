---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import ContentLayout from "astro-theme-university/layouts/ContentLayout.astro";
import Pagination from "astro-theme-university/components/Pagination.astro";
import { siteConfig } from "../../site-config";
import { PAGE_SIZE } from "../../lib/outputs";
import { pageHero } from "../../lib/heroes";
import OutputCardGrid from "../../components/OutputCardGrid.astro";
import OutputTypeFilter from "../../components/OutputTypeFilter.astro";
import OutputsDashboard from "../../components/OutputsDashboard.astro";

// Rest-param pagination: page 1 renders at /outputs/, later pages at
// /outputs/2/, ... Output ids are never bare numbers, so this can't collide
// with the /outputs/[id]/ landing pages. The per-type views live under
// /outputs/type/<slug>/ and paginate the same way --- see the sibling route.
export const getStaticPaths = (async ({ paginate }) => {
  const outputs = (await getCollection("outputs")).toSorted(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(outputs, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;

// The dashboard summarises the whole collection, so it renders on page 1 only;
// later pages carry just the filter and the card grid.
const firstPage = page.currentPage === 1;
---

<ContentLayout
  title="Research outputs"
  description="The published research outputs of Slop University."
  heroImage={pageHero("outputs")}
  heroImageAlt={pageHero("outputs") ? "The Slop University research repository" : undefined}
  {...siteConfig}
>
  <p class="lead">
    All research outputs of the University are published open access under{" "}
    <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>, with
    persistent identifiers minted by the Office of Research Outputs.
  </p>

  {firstPage && <OutputsDashboard />}

  <h2>Published outputs</h2>
  {
    page.total === 0 && (
      <p>The repository is awaiting its first deposit.</p>
    )
  }

  <OutputTypeFilter />
  <OutputCardGrid entries={page.data} />

  {page.lastPage > 1 && <Pagination page={page} />}
</ContentLayout>
