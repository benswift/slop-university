---
import type { ImageMetadata } from "astro";
import BaseLayout from "astro-theme-university/layouts/BaseLayout.astro";
import { siteConfig } from "../site-config";

const props = Astro.props.frontmatter ?? Astro.props;
const { title, heroImage, ...rest } = props as {
  title: string;
  heroImage?: string | ImageMetadata;
  [key: string]: unknown;
};
---

<BaseLayout title={`${title} — ${siteConfig.name}`} {...siteConfig} {...rest} heroImage={heroImage}>
  <slot />
</BaseLayout>
